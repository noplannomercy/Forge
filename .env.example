# ============================================================
# Forge — Document Converter Service
# 실제 값으로 교체 후 .env 로 저장. 절대 커밋 금지.
# ============================================================

# ---- VLM (필수) ----
# OpenRouter / Ollama / OpenAI-compatible 엔드포인트
VLM_URL=https://openrouter.ai/api/v1/chat/completions
VLM_MODEL=google/gemini-2.0-flash-001
VLM_API_KEY=REPLACE_ME
VLM_TIMEOUT=120
VLM_CONCURRENCY=3
VLM_BATCH_SIZE=5

# ---- 서버 ----
HOST=0.0.0.0
PORT=8003
MAX_FILE_SIZE=104857600

# ---- DB (PostgreSQL — 미설정 시 InMemory) ----
# 형식: postgresql://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=postgresql://USER:PASS@DB_HOST:5432/DB_NAME

# ---- 메타 추출 LLM (미설정 시 VLM_* fallback) ----
META_LLM_URL=
META_LLM_MODEL=
META_LLM_API_KEY=

# ---- 관리 API 인증 (미설정 시 /jobs, /stats, /prompts 비활성화) ----
FORGE_API_KEY=

# ---- Callback 인증 (Cortex 등 downstream의 X-API-Key 헤더 값) ----
CALLBACK_API_KEY=
